; md.mdp — production MD (apo-HEL), 20 ns, pipeline-validation + RMSF feature
; NOTE: 20 ns / single replica is a validation length. Converged RMSF as a real feature
;       will need longer + replicas (>=3) — decide before treating RMSF as a feature.
integrator              = md
dt                      = 0.002
nsteps                  = 10000000      ; 20 ns
continuation            = yes           ; velocities from NPT checkpoint

; Output
nstxout                 = 0
nstvout                 = 0
nstfout                 = 0
nstxout-compressed      = 5000          ; .xtc every 10 ps
nstenergy               = 5000
nstlog                  = 5000

; Neighbour searching
cutoff-scheme           = Verlet
nstlist                 = 10
ns_type                 = grid
pbc                     = xyz

; Electrostatics / vdW
coulombtype             = PME
rcoulomb                = 1.0
pme_order               = 4
fourierspacing          = 0.16
rvdw                    = 1.0
vdw-modifier            = Potential-shift-Verlet
DispCorr                = EnerPres

; Temperature coupling
tcoupl                  = V-rescale
tc-grps                 = Protein  Non-Protein
tau_t                   = 0.1      0.1
ref_t                   = 300      300

; Pressure coupling (Parrinello-Rahman for production)
pcoupl                  = Parrinello-Rahman
pcoupltype              = isotropic
tau_p                   = 2.0
ref_p                   = 1.0
compressibility         = 4.5e-5

; Constraints
constraints             = h-bonds
constraint_algorithm    = LINCS
lincs_iter              = 1
lincs_order             = 4

; No position restraints, no velocity generation in production
gen_vel                 = no
ld_seed                 = 20260618
